# ── Backend ─────────────────────────────────────────────────────
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── GitHub OAuth ────────────────────────────────────────────────
GITHUB_CLIENT_ID=         # GitHub OAuth App Client ID
GITHUB_CLIENT_SECRET=     # GitHub OAuth App Client Secret
GITHUB_CALLBACK_URL=      # OAuth callback URL (e.g. http://localhost:3000/api/github/callback)

# ── Frontend (exposed to browser via Vite) ─────────────────────
VITE_GITHUB_CLIENT_ID=    # GitHub OAuth App Client ID (public)

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # GitHub user ID of the app creator; this user gets role "admin" on first login

# ── GitHub API ──────────────────────────────────────────────────
GITHUB_TOKEN=             # Optional GitHub Personal Access Token (increases rate limit from 60 to 5000 req/hour)
